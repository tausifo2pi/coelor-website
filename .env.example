# ── App vars (.env) ──────────────────────────────────────────────────────────
# NEXT_PUBLIC_* are baked into the Docker image at build time.
# Push to GitHub via: cd infra && npm run push-secrets

# NEXT_PUBLIC_SITE_URL=https://coelor.com

# ── CI / Deploy secrets (.env.ci) ────────────────────────────────────────────
# Push to GitHub via: cd infra && npm run push-ci-secrets

SSH_PRIVATE_KEY=        # PEM from `pulumi stack output privateKeyPem`
API_SERVER=             # EC2 elastic IP from `pulumi stack output publicIp`
DOCKER_HUB_USER=        # Docker Hub username
DOCKER_HUB_PASSWORD=    # Docker Hub password or access token
DOCKER_HUB_REPO=        # e.g. coelor-website
CI_COMMIT_REF_NAME=     # Docker image tag, e.g. latest
